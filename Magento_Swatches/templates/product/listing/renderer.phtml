declare(strict_types=1);

use Hyva\Theme\ViewModel\HyvaCsp;
use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\SwatchRenderer;
use Magento\Framework\Escaper;
use Magento\Swatches\Block\Product\Renderer\Listing\Configurable;
use Magento\Swatches\ViewModel\Product\Renderer\Configurable as ConfigurableViewModel;

/** @var Configurable $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
/** @var HyvaCsp $hyvaCsp */

/** @var ConfigurableViewModel $configurableViewModel */
$configurableViewModel = $viewModels->require(ConfigurableViewModel::class);

$product = $block->getProduct();
$productId = $product->getId();

$attributes = $block->decorateArray($block->getAllowAttributes());

/** @var SwatchRenderer $swatchRendererViewModel */
$swatchRendererViewModel = $viewModels->require(SwatchRenderer::class);

$layout = $block->getLayout();
$swatchItemBlock = $layout->getBlock('product.swatch.item');
$swatchItemBlock->setData('product_id', $productId);

// getJsonConfig() resets and populates allow_products for this product; calling it first
// means getJsonSwatchConfig() hits the warm cache instead of re-querying.
$jsonConfig = $block->getJsonConfig();
$jsonSwatchConfig = $block->getJsonSwatchConfig();
$swatchConfig = json_decode($jsonSwatchConfig, true);
?>
<?php if ($product->isSaleable() && count($attributes)): ?>
    <script>
        function initConfigurableSwatchOptions() {
            const { productId, mediaCallback } = this.$root.dataset;
            const configEl = this.$root.querySelector('script[type="application/json"]');
            if (!configEl) {
                throw new Error(`initConfigurableSwatchOptions:
                    missing inline JSON config in component root,
                    outdated renderer.phtml override?`);
            }

            const configurableOptionsComponent = initConfigurableOptions(productId, JSON.parse(configEl.textContent));
            const swatchOptionsComponent = initSwatchOptions();
            return Object.assign(
                configurableOptionsComponent,
                swatchOptionsComponent,
                {
                    init() {
                        this.baseInit();
                        this.preselectQuerystringItems();
                        this.applyCheckedState();
                        this.applySelectionToLinks();
                    },
                    applySelectionToLinks() {
                        const form = this.$root.closest('form');
                        if (!form) return;
                        form.querySelectorAll('a.product-item-link, a.product-item-photo').forEach(link => {
                            try {
                                const url = new URL(link.href);
                                Object.values(this.optionConfig.attributes).forEach(attr => {
                                    const val = this.selectedValues[attr.id];
                                    if (val) url.searchParams.set(attr.code, val);
                                });
                                link.href = url.toString();
                            } catch (e) {}
                        });
                    },
                    changeOption(attributeId, value) {
                        this.baseChangeOption(attributeId, value);
                        window.dispatchEvent(new CustomEvent('listing-configurable-selection-changed', {
                            detail: {
                                productId: this.productId,
                                optionId: attributeId,
                                value,
                                selectedValues: this.selectedValues,
                                productIndex: this.productIndex,
                            }
                        }));
                    },
                    updateGallery() {
                        if (!this.productIndex) return;
                        fetch(`${mediaCallback}?product_id=${this.productIndex}&isAjax=true`, {
                            method: 'GET',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.errors) {
                                console.warn(data.errors);
                                return;
                            }
                            data && window.dispatchEvent(
                                new CustomEvent(`update-gallery-${this.productId}`, { detail: data })
                            );
                        })
                        .catch(error => console.warn(error));
                    }
                }
            );
        }

        window.addEventListener('alpine:init', () => {
            Alpine.data('initConfigurableSwatchOptions', initConfigurableSwatchOptions)
        }, { once: true });
    </script>
    <?php $hyvaCsp->registerInlineScript() ?>

    <div
        x-data="initConfigurableSwatchOptions"
        x-defer="intersect"
        data-product-id="<?= (int) $productId ?>"
        data-media-callback="<?= $escaper->escapeUrl($block->getMediaCallback()) ?>"
        class="mb-2 relative"
    >
        <script type="application/json"><?= /* @noEscape */ str_replace('</script>', '<\/script>', $jsonConfig) ?></script>

        <?php foreach ($attributes as $attribute): ?>
            <?php
            $attributeId = $attribute->getAttributeId();
            $productAttribute = $attribute->getProductAttribute();

            if (!$productAttribute->getUsedInProductListing() ||
                !$swatchRendererViewModel->isSwatchAttribute($productAttribute)) {
                continue;
            }

            $productOptions = $attribute->getOptions();
            $attributeSwatchConfig = $swatchConfig[$attributeId] ?? [];
            ?>
            <fieldset class="mt-4">
                <legend class="mb-1 text-sm font-medium">
                    <?= $escaper->escapeHtml($productAttribute->getStoreLabel()) ?>
                </legend>
                <div class="flex flex-wrap gap-1">
                    <?php foreach ($productOptions ?? [] as $option): ?>
                        <?= /* @noEscape */ $swatchItemBlock
                            ->setData('option', $option)
                            ->setData('swatch_data', $attributeSwatchConfig[$option['value_index']] ?? null)
                            ->setData('attribute_id', $attributeId)
                            ->toHtml(); ?>
                    <?php endforeach; ?>
                </div>
            </fieldset>
        <?php endforeach; ?>
        <?php if ($configurableViewModel->getShowSwatchTooltip()): ?>
            <?= /* @noEscape */ $block->getBlockHtml('product.swatch.tooltip') ?>
        <?php endif; ?>
    </div>
<?php endif; ?>
