declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\SwatchRenderer;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;
use Magento\Swatches\Model\Swatch;
use Magento\Swatches\ViewModel\Product\Renderer\Configurable as ConfigurableViewModel;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var ConfigurableViewModel $configurableViewModel */
$configurableViewModel = $viewModels->require(ConfigurableViewModel::class);

/** @var SwatchRenderer $swatchRendererViewModel */
$swatchRendererViewModel = $viewModels->require(SwatchRenderer::class);

$productId = $block->getProductId();
$attributeId = $block->getAttributeId();
$option = $block->getOption();

if (!$block->hasData('option')) {
    throw new \RuntimeException(
        'product.swatch.item rendered without "option" data — your theme likely overrides '
        . 'Magento_Swatches::product/.../renderer.phtml from a pre-1.5 Hyvä version. See the upgrade guide.'
    );
}
if (!$productId || !$attributeId || !$option) { return ''; }

$optionId = $option['value_index'];
$optionLabel = $option['store_label'];
$id = "attribute-option" . $productId . "-" . $optionId;

$swatchData = $block->getSwatchData();
if (!$swatchData) {
    return '';
}
$swatchType = (int) ($swatchData['type'] ?? Swatch::SWATCH_TYPE_TEXTUAL);
$isVisual = in_array($swatchType, [Swatch::SWATCH_TYPE_VISUAL_COLOR, Swatch::SWATCH_TYPE_VISUAL_IMAGE], true);

$swatchImgWidth = $swatchRendererViewModel->getSwatchDimension('swatch_image', 'width', 30);
$swatchImgHeight = $swatchRendererViewModel->getSwatchDimension('swatch_image', 'height', 30);
$swatchImgThumbWidth = $swatchRendererViewModel->getSwatchDimension('swatch_thumb', 'width', 90);
$swatchImgThumbHeight = $swatchRendererViewModel->getSwatchDimension('swatch_thumb', 'height', 90);

$toolTipData = [
    'preview' => $swatchData['thumb'] ?? $swatchData['value'] ?? null,
    'label' => $optionLabel,
    'type' => $swatchType === Swatch::SWATCH_TYPE_VISUAL_COLOR
        ? 'color'
        : ($swatchType === Swatch::SWATCH_TYPE_VISUAL_IMAGE ? 'image' : 'text'),
    'width' => $swatchImgThumbWidth,
    'height' => $swatchImgThumbHeight,
];
?>
<label
    for="<?= $escaper->escapeHtmlAttr($id) ?>"
    class="swatch-option my-0"
    data-swatch-type="<?= $escaper->escapeHtmlAttr($isVisual ? 'visual' : 'text') ?>"
    <?php if ($isVisual && $configurableViewModel->getShowSwatchTooltip()): ?>
        @mouseenter.self="showTooltip"
        @mouseleave.self="hideTooltip"
    <?php endif; ?>
>
    <?php if ($swatchType === Swatch::SWATCH_TYPE_VISUAL_COLOR): ?>
        <span
            class="block"
            style="<?= $escaper->escapeHtmlAttr(implode(';', [
                'width:' . $swatchImgWidth . 'px',
                'height:' . $swatchImgHeight . 'px',
                'background-color:' . $swatchData['value'],
            ])); ?>"
        ></span>
        <span class="sr-only"><?= $escaper->escapeHtml($optionLabel) ?></span>
    <?php elseif ($swatchType === Swatch::SWATCH_TYPE_VISUAL_IMAGE): ?>
        <img
            src="<?= $escaper->escapeUrl($swatchData['value']) ?>"
            alt="<?= $escaper->escapeHtmlAttr($optionLabel) ?>"
            width="<?= $escaper->escapeHtmlAttr($swatchImgWidth) ?>"
            height="<?= $escaper->escapeHtmlAttr($swatchImgHeight) ?>"
            loading="lazy"
        >
    <?php else: ?>
        <span><?= $escaper->escapeHtml($optionLabel) ?></span>
    <?php endif; ?>
    <input
        id="<?= $escaper->escapeHtmlAttr($id) ?>"
        type="radio"
        name="super_attribute[<?= $escaper->escapeHtml($attributeId) ?>]"
        value="<?= $escaper->escapeHtml($optionId) ?>"
        @change="reflectOption"
        data-attribute-id="<?= $escaper->escapeHtmlAttr($attributeId) ?>"
        data-option-label="<?= $escaper->escapeHtmlAttr($optionLabel) ?>"
        <?php if ($isVisual && $configurableViewModel->getShowSwatchTooltip()): ?>
            data-tooltip="<?= $escaper->escapeHtmlAttr(json_encode($toolTipData)) ?>"
        <?php endif; ?>
        :disabled="optionIsDisabled"
        required
        class="opacity-0 size-full m-0"
    >
</label>
