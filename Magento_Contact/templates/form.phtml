declare(strict_types=1);

use Magento\Contact\Block\ContactForm;
use Magento\Contact\Helper\Data as ContactHelper;
use Magento\Framework\Escaper;
use Hyva\Theme\ViewModel\ReCaptcha;

// phpcs:disable Magento2.Templates.ThisInTemplate.FoundThis
// phpcs:disable Magento2.Templates.ThisInTemplate.FoundHelper

/** @var ContactForm $block */
/** @var Escaper $escaper */
/** @var ReCaptcha $recaptcha|null */

$formId = 'contact';
/** @var ContactHelper $contactHelper */
$contactHelper = $this->helper(ContactHelper::class);

// Do not replace this with $viewModels->require(ReCaptcha::class); that would break the dependency
// on the Magento_ReCaptchaContact module
$recaptcha = $block->getData('viewModelRecaptcha');
?>
<div class="flex flex-col md:flex-row justify-between py-8 gap-4">
    <form class="form contact card lg:w-1/2 md:w-2/3"
          action="<?= $escaper->escapeUrl($block->getFormAction()) ?>"
          id="<?= $escaper->escapeHtmlAttr($formId) ?>"
          method="post"
          x-data="initContactForm()"
          @submit.prevent="submitForm()"
    >
        <fieldset>
            <legend class="text-xl sm:text-2xl font-medium mb-4">
                <?= $escaper->escapeHtml(__('Write Us')) ?>
            </legend>
            <p><?= $escaper->escapeHtml(__('Jot us a note and we’ll get back to you as quickly as possible.')) ?></p>
            <div class="grid grid-cols-2 gap-2 my-4">
                <div class="field name required">
                    <label for="name"><?= $escaper->escapeHtml(__('Name')) ?></label>
                    <input
                        type="text"
                        id="name"
                        name="name"
                        value="<?= $escaper->escapeHtmlAttr(
                            $contactHelper->getPostValue('name') ?: $contactHelper->getUserName()
                        ) ?>"
                        required
                        autocomplete="name"
                        class="form-input w-full"
                    >
                </div>
                <div class="field email required">
                    <label for="email"><?= $escaper->escapeHtml(__('Email')) ?></label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        value="<?= $escaper->escapeHtmlAttr(
                            $contactHelper->getPostValue('email') ?: $contactHelper->getUserEmail()
                        ) ?>"
                        autocomplete="email"
                        class="form-input w-full"
                    >
                </div>
                <div class="field telephone">
                    <label for="telephone"><?= $escaper->escapeHtml(__('Phone Number')) ?></label>
                    <input
                        type="text"
                        id="telephone"
                        name="telephone"
                        value="<?= $escaper->escapeHtmlAttr($contactHelper->getPostValue('telephone')) ?>"
                        autocomplete="tel"
                        class="form-input w-full"
                    >
                </div>
                <div class="field comment required col-span-full">
                    <label for="comment"><?= $escaper->escapeHtml(__('What’s on your mind?')) ?></label>
                    <textarea
                        name="comment"
                        id="comment"
                        required
                        class="form-input w-full"
                        rows="3"
                        autocomplete="off"
                    ><?= $escaper->escapeHtml($contactHelper->getPostValue('comment')) ?></textarea>
                </div>
            </div>
            <?= $block->getChildHtml('form.additional.info') ?>
            <?= $recaptcha ? $recaptcha->getInputHtml(ReCaptcha::RECAPTCHA_FORM_ID_CONTACT) : '' ?>
        </fieldset>
        <div>
            <?= $block->getBlockHtml('formkey') ?>
            <button type="submit" class="btn btn-primary">
                <?= $escaper->escapeHtml(__('Submit')) ?>
            </button>
        </div>
        <div>
            <?= $block->getChildHtml('form.additional.after') ?>
            <?= $recaptcha ? $recaptcha->getLegalNoticeHtml(ReCaptcha::RECAPTCHA_FORM_ID_CONTACT) : '' ?>
        </div>
    </form>
    <script>
        function initContactForm() {
            return {
                errors: 0,
                hasCaptchaToken: 0,
                submitForm() {
                    // Do not rename $form, the variable is expected to be declared in the recaptcha output
                    const $form = document.querySelector('#<?= $escaper->escapeJs($formId) ?>');
                    <?= $recaptcha ? $recaptcha->getValidationJsHtml(ReCaptcha::RECAPTCHA_FORM_ID_CONTACT) : '' ?>

                    if (this.errors === 0) {
                        $form.submit();
                    }
                }
            }
        }
    </script>
    <div class="card lg:w-1/2 md:w-1/3">
        <?= $block->getChildHtml('contact.details') ?>
    </div>
</div>
